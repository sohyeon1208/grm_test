# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# service account keys (JSON) - NEVER commit
*service-account*.json
*-iam-*.json
crypto-resolver-*.json

# local debug scripts (filename starts with underscore)
/_*.mjs
/_*.js

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# 인수인계 문서 (로컬 참고용)
HANDOFF.md
